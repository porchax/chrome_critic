{
  "name": "@criticus/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "migrate": "tsx src/db/migrate.ts",
    "build": "tsc && cp -R src/db/migrations dist/db/migrations && cp -R src/llm/prompts dist/llm/prompts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@criticus/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "4.6.10",
    "ioredis": "^5.6.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.3",
    "tsx": "^4.19.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "msw": "2.6.4",
    "pg-mem": "^2.8.1",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
